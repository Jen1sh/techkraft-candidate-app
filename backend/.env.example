# TechKraft Candidate Score API — Environment Configuration
# Copy this file to .env and fill in your values.

# Secret key used for JWT token signing.
# Generate a strong key for production: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# JWT algorithm (default: HS256)
# ALGORITHM=HS256

# Token expiry in minutes (default: 60)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
